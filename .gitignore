# Monorepo root .gitignore
# Sub-projects (web/, server/) maintain their own .gitignore for
# project-specific rules. Rules here apply across the whole tree.

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor / IDE
.idea
*.swp
*.swo
*~

# Logs
*.log

# Cache / temp
.cache/
.tmp/
tmp/
.history/

# Local sandbox / scratch
_test_file
*.local
